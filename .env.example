# Local development:
#   copy this file to `.env.local`
#
# Production:
#   add the same keys in Vercel Project Settings -> Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: personal access token for Supabase CLI auto-login during Codex/CLI checks
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token

# Google / AI
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Use a long random string (32+ chars) to encrypt stored Google refresh tokens
GOOGLE_CALENDAR_TOKEN_SECRET=your_long_random_secret
# Optional: if omitted, the app uses {origin}/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://coatly.vercel.app/api/integrations/google-calendar/callback

# Australian Business Register (ABR) Web Services
ABR_GUID=your_abn_lookup_guid

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# App URL
NEXT_PUBLIC_APP_URL=https://coatly.vercel.app
