NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: personal access token for Supabase CLI auto-login during Codex/CLI checks
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token
GEMINI_API_KEY=your_gemini_api_key
ABR_GUID=your_abn_lookup_guid

# Stripe — https://dashboard.stripe.com/test/apikeys  (use TEST keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — create in dashboard or via `stripe prices list`
# Products: Coatly Starter (A$29/mo, A$24/mo annual)
#           Coatly Pro     (A$49/mo, A$39/mo annual)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# Used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
