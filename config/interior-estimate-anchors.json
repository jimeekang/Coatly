  "estimate_form_reference": {
    "_description": "Suggested form fields and options for each scenario.",

    "apartment_entire": {
      "required_fields": [
        { "field": "property_type",  "type": "select",  "options": ["Studio", "1 Bedroom", "2 Bedroom (Standard)", "2 Bedroom (Large)", "3 Bedroom"] },
        { "field": "sqm",            "type": "number",  "label": "Apartment size (sqm)", "optional": true, "note": "Enables sqm-curve pricing if provided" },
        { "field": "condition",      "type": "select",  "options": ["Excellent", "Fair", "Poor"] },
        { "field": "scope",          "type": "multiselect", "options": ["Walls", "Ceiling", "Trim / Skirting"], "default": ["Walls", "Ceiling", "Trim / Skirting"] }
      ]
    },

    "apartment_specific": {
      "required_fields": [
        { "field": "rooms",          "type": "multiselect", "options": ["Master Bedroom", "Bedroom 1", "Bedroom 2", "Bedroom 3", "Bathroom", "Living Room", "Lounge", "Dining", "Kitchen", "Study / Office", "Laundry", "Hallway", "Foyer", "Stairwell", "Walk-in Robe", "Other"] },
        { "field": "condition",      "type": "select",  "options": ["Excellent", "Fair", "Poor"] },
        { "field": "paint_system",   "type": "select",  "options": ["oil_2coat", "water_3coat_white_finish"] },
        { "field": "doors",          "type": "items",   "optional": true, "sub_fields": ["style", "scope", "quantity"] },
        { "field": "windows",        "type": "items",   "optional": true, "sub_fields": ["type", "scope", "quantity"] },
        { "field": "skirting_lm",    "type": "number",  "label": "Skirting linear metres", "optional": true }
      ]
    },

    "house_entire": {
      "required_fields": [
        { "field": "bedrooms",       "type": "number",  "label": "Number of bedrooms" },
        { "field": "bathrooms",      "type": "number",  "label": "Number of bathrooms" },
        { "field": "storeys",        "type": "select",  "options": ["1 Storey", "2 Storey", "3 Storey"] },
        { "field": "sqm",            "type": "number",  "label": "Approx. house size (sqm)", "optional": true },
        { "field": "condition",      "type": "select",  "options": ["Excellent", "Fair", "Poor"] },
        { "field": "scope",          "type": "multiselect", "options": ["Walls", "Ceiling", "Trim / Skirting"], "default": ["Walls", "Ceiling", "Trim / Skirting"] }
      ]
    },

    "house_specific": {
      "required_fields": [
        { "field": "rooms",          "type": "multiselect", "options": ["Master Bedroom", "Bedroom 1", "Bedroom 2", "Bedroom 3", "Bathroom", "Living Room", "Lounge", "Dining", "Kitchen", "Study / Office", "Laundry", "Hallway", "Foyer", "Stairwell", "Walk-in Robe", "Other"] },
        { "field": "storeys",        "type": "select",  "options": ["1 Storey", "2 Storey", "3 Storey"] },
        { "field": "condition",      "type": "select",  "options": ["Excellent", "Fair", "Poor"] },
        { "field": "paint_system",   "type": "select",  "options": ["oil_2coat", "water_3coat_white_finish"] },
        { "field": "doors",          "type": "items",   "optional": true, "sub_fields": ["style", "scope", "quantity"] },
        { "field": "windows",        "type": "items",   "optional": true, "sub_fields": ["type", "scope", "quantity"] },
        { "field": "skirting_lm",    "type": "number",  "label": "Skirting linear metres", "optional": true }
      ]
    }
  },

  "calculation_flow": {
    "_description": "Step-by-step calculation guide for each scenario.",

    "apartment_entire": [
      "1. If sqm provided → use sqm_curve interpolation to get median",
      "2. Else → use apt_type anchor (min/max/median)",
      "3. Apply scope_area_share multiplier based on selected scope",
      "4. Apply condition multiplier (apartment.condition)",
      "5. Clamp max − min gap (≤ AUD 1200 if total ≤ 5000, else ≤ 1800)",
      "6. Cap total at AUD 35000"
    ],

    "apartment_specific": [
      "1. Sum selected room medians (from rooms anchor)",
      "2. Add trim items: doors × price, windows × price, skirting × lm_rate",
      "3. Apply qty scale factor to door/window totals",
      "4. Apply condition multiplier (apartment.condition) to room sub-total",
      "5. Trim items are NOT condition-adjusted (labour is fixed)",
      "6. Cap total at AUD 35000"
    ],

    "house_entire": [
      "1. Infer config key from bedrooms/bathrooms (or sqm fallback)",
      "2. Get min/max/median from by_config",
      "3. Apply scope_area_share multiplier based on selected scope",
      "4. Apply storey multiplier (modifiers.storeys)",
      "5. Apply condition multiplier (house.condition)",
      "6. If double storey 3B2B → apply double_storey_3b2b_uplift on top",
      "7. Clamp max − min gap (≤ AUD 1800 if total ≤ 10000, else ≤ 2500)",
      "8. Cap total at AUD 35000"
    ],

    "house_specific": [
      "1. Sum selected room medians (from rooms anchor)",
      "2. Apply storey multiplier to room sub-total",
      "3. Add trim items: doors × price, windows × price, skirting × lm_rate",
      "4. Apply qty scale factor to door/window totals",
      "5. Apply condition multiplier (house.condition) to room sub-total",
      "6. Cap total at AUD 35000"
    ]
  }
}
